<?xml version="1.0"?>
<ruleset name="ABW-AI">
    <description>Coding Standards for ABW-AI Plugin</description>
    
    <!-- What to scan -->
    <file>.</file>
    
    <!-- Exclude vendor and node_modules -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    
    <!-- How to scan -->
    <arg value="sp"/> <!-- Show sniff and progress -->
    <arg name="basepath" value="./"/>
    <arg name="colors"/>
    <arg name="extensions" value="php"/>
    <arg name="parallel" value="8"/>
    
    <!-- Rules: Check PHP version compatibility -->
    <config name="testVersion" value="7.4-"/>
    
    <!-- Use PSR-12 but exclude rules that conflict with WordPress conventions -->
    <rule ref="PSR12">
        <!-- Allow snake_case method names (WordPress standard) -->
        <exclude name="PSR1.Methods.CamelCapsMethodName.NotCamelCaps"/>
        <!-- Allow classes without namespaces (WordPress standard) -->
        <exclude name="PSR1.Classes.ClassDeclaration.MissingNamespace"/>
        <!-- Allow underscore-prefixed class names (WordPress standard) -->
        <exclude name="Squiz.Classes.ValidClassName.NotCamelCaps"/>
        <exclude name="Squiz.Classes.ValidClassName.NotPascalCase"/>
        <!-- Allow file with side effects and declarations (WordPress standard) -->
        <exclude name="PSR1.Files.SideEffects.FoundWithSymbols"/>
    </rule>
</ruleset>
